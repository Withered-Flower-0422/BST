{
    "compilerOptions": {
        "strict": true,
        "isolatedModules": true,
        "noImplicitReturns": true,
        "noUncheckedIndexedAccess": true,
        "noFallthroughCasesInSwitch": true,
        "exactOptionalPropertyTypes": true,
        "noEmit": true,
        "target": "es2024",
        "module": "node20",
        "lib": ["ES2025"],
        "checkJs": true,
        "paths": {
            "Scripts/*": ["./*"]
        }
    },
    "include": [
        // "Samples/**/*",
        // "Templates/**/*",
        // "test/js/**/*",
        "_Typings/**/*",
        "test/ts/**/*"
    ]
}
